class Solution {
public:
    int longestContinuousSubstring(string s) {
        int n = s.size();
        int len = 1;
        int ans = 1;
        for(int i =  1 ; i < n ; i++){
            if(s[i] == s[i-1] +1){
                len++;
            }
            else { 
                len = 1;
            }
                        ans = max(ans, len);

        }
        return ans;
    }
};
